# The format of this file is identical to `.dockerignore`.
# It is used to reduce the size of deployed images to make the process of publishing faster.

# pnpm store (already excluded — keep this)
.local

# node_modules are not needed in production:
# - API server is bundled by esbuild into a single dist/index.mjs file
# - Frontend is compiled to static files by Vite
**/node_modules

# Development-only tools (canvas mockup sandbox, not part of the live app)
artifacts/mockup-sandbox

# Uploaded assets (images used during development/planning)
attached_assets

# TypeScript build info files
**/*.tsbuildinfo

# Git history
.git

# Test and coverage artifacts
**/coverage
**/.cache
