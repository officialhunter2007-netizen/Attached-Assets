    "@types/ws": "^8.5.10",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-anthropic-ai": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "drizzle-orm": "catalog:",
    "express": "^4.19.2",
    "google-auth-library": "^9.11.0",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "pino": "^9.2.0",
