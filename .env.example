# ═══════════════════════════════════════════════════════════════════
# ملف المتغيّرات البيئية - نُخبة للإنتاج
# انسخ هذا الملف إلى .env وأكمل القيم الناقصة
# لا ترفع ملف .env إلى GitHub أبداً
# ═══════════════════════════════════════════════════════════════════

# ─── قاعدة البيانات ───────────────────────────────────────────────
POSTGRES_DB=nukhba
POSTGRES_USER=nukhba
# اختر كلمة مرور قوية (أكثر من 20 حرفاً)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ─── الجلسات ──────────────────────────────────────────────────────
# سلسلة عشوائية طويلة - شغّل: openssl rand -hex 64
SESSION_SECRET=CHANGE_ME_RUN_openssl_rand_hex_64

# ─── Anthropic (Claude AI - مطلوب) ───────────────────────────────
AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com

# ─── Google Gemini (اختياري - للمواد التي تستخدمه) ───────────────
GEMINI_API_KEY=

# ─── Google OAuth (تسجيل الدخول بـGoogle) ────────────────────────
# أنشئها من: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── الموقع والمشرفون ─────────────────────────────────────────────
# اسم الدومين الخاص بك (بدون https://)
APP_DOMAIN=learnukhba.com

# البريد الإلكتروني للمشرفين (يمكن الفصل بفاصلة)
ADMIN_EMAILS=admin@learnukhba.com

# المستخدمون الذين لديهم وصول غير محدود (اختياري)
UNLIMITED_ACCESS_EMAILS=

# ─── تسجيل الأحداث ────────────────────────────────────────────────
LOG_LEVEL=info
