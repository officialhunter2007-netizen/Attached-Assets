# ═══════════════════════════════════════════════════════════════════
# OpenRouter — مفتاح المعلّم الذكي (الأهم!)
# ═══════════════════════════════════════════════════════════════════
# • هذا المفتاح ضروري لتشغيل المعلّم الذكي والملخصات والشرح.
# • احصل عليه من: https://openrouter.ai/keys
# • يجب أن يبدأ بـ sk-or-  (وليس sk- أو sk-ant-).
# • بدونه ستظهر تنبيهات "openrouter_auth_failed" في لوحة الإدارة.
OPENROUTER_API_KEY=sk-or-v1-ضع_مفتاح_OpenRouter_هنا

# ═══════════════════════════════════════════════════════════════════
# تكامل OpenAI / Anthropic (اختياري - يمكن تركه فارغاً)
# ═══════════════════════════════════════════════════════════════════
AI_INTEGRATIONS_OPENAI_BASE_URL=https://openrouter.ai/api/v1
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1
AI_INTEGRATIONS_ANTHROPIC_API_KEY=

# Gemini مباشر (اختياري)
GEMINI_API_KEY=

# ═══════════════════════════════════════════════════════════════════
# fal.ai — الصور التوضيحية للمعلّم الذكي (FLUX schnell)
# ═══════════════════════════════════════════════════════════════════
# • اختياري: لو تركته فارغاً ستعمل المنصة بدون صور توضيحية inline.
# • احصل على المفتاح من: https://fal.ai/dashboard/keys
# • شكل القيمة عادةً:  KEY_ID:KEY_SECRET  (سلسلتان مفصولتان بنقطتين)
# • التكلفة: ≈ $0.003 لكل صورة (يخصم 3 جواهر من الطالب لكل صورة).
# • معدّل محدود تلقائياً: 5 صور/دقيقة لكل طالب، 1 صورة في درس الافتتاح.
FAL_KEY=

# ═══════════════════════════════════════════════════════════════════
# قاعدة البيانات المحلية (Docker على الـ VPS)
# docker-compose يبني DATABASE_URL تلقائياً من هذه المتغيرات
# ═══════════════════════════════════════════════════════════════════
POSTGRES_DB=nukhba
POSTGRES_USER=nukhba_user
POSTGRES_PASSWORD=ضع_كلمة_مرور_قوية_هنا

