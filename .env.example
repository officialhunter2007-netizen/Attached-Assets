# ═══════════════════════════════════════════════════════════════════
# ملف المتغيّرات البيئية - نُخبة للإنتاج (VPS + Docker)
# انسخ هذا الملف إلى .env وأكمل القيم الناقصة
# لا ترفع ملف .env إلى GitHub أبداً
# ═══════════════════════════════════════════════════════════════════

# ─── قاعدة البيانات (Neon PostgreSQL الخارجي) ─────────────────────
DATABASE_URL=postgresql://neondb_owner:كلمة_المرور@ep-xxxx.neon.tech/neondb?sslmode=require

# ─── الجلسات ──────────────────────────────────────────────────────
# شغّل هذا الأمر لإنشاء قيمة عشوائية: openssl rand -hex 64
SESSION_SECRET=CHANGE_ME_RUN_openssl_rand_hex_64

# ─── OpenRouter (مفتاح واحد يغطّي OpenAI + Anthropic) ─────────────
# احصل على المفتاح من: https://openrouter.ai/settings/keys
AI_INTEGRATIONS_OPENAI_BASE_URL=https://openrouter.ai/api/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXX

AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1
AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXX

# ─── Google Gemini (للمساعد العام - مجاني) ────────────────────────
# احصل على مفتاح مجاني من: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Google OAuth (تسجيل الدخول بحساب Google) ────────────────────
# أنشئها من: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── الموقع والمشرفون ─────────────────────────────────────────────
# اسم الدومين الخاص بك (بدون https://)
APP_DOMAIN=nukhba.example.com

# البريد الإلكتروني للمشرفين (يمكن الفصل بفاصلة)
ADMIN_EMAILS=admin@nukhba.example.com

# المستخدمون الذين لديهم وصول غير محدود (اختياري)
UNLIMITED_ACCESS_EMAILS=

# ─── تسجيل الأحداث ────────────────────────────────────────────────
LOG_LEVEL=info
